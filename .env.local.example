# Application
NEXT_PUBLIC_APP_NAME="Modern Tech Stack"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database - Replace with your PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/modern_stack?schema=public"

# Authentication - Use a secure random string in production (generate with: openssl rand -hex 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-auth-key-change-in-production"

# GitHub OAuth (optional)
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
