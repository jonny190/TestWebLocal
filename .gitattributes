# Auto detect text files and perform LF normalization
* text=auto

# Special cases for different line endings
*.sh text eol=lf
*.ps1 text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.avif binary

# Executables
*.exe binary
*.dll binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Lock files (keep them as-is)
package-lock.json binary
yarn.lock binary
pnpm-lock.yaml binary
